<Window x:Class="RelojControl.Windows.WndEnrolador"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:RelojControl.Controls"
        WindowStyle="None" ResizeMode="NoResize"
        WindowState="Maximized" Topmost="True"
        Background="{StaticResource BgBrush}"
        KeyDown="Window_KeyDown">
  <Grid>
    <Viewbox Stretch="Uniform">
      <ctrl:UcEnrolador x:Name="uc"/>
    </Viewbox>
    <WindowsFormsHost x:Name="ecHost" Width="495" Height="314"
                      HorizontalAlignment="Left" VerticalAlignment="Top"
                      Margin="-1000,-1000,0,0"/>
  </Grid>
</Window>
