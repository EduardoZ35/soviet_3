<Window x:Class="RelojControl.Windows.WndEnrolador"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize" WindowState="Maximized" Topmost="True"
        Background="{StaticResource BgBrush}"
        KeyDown="Window_KeyDown">

  <Window.Resources>
    <Style x:Key="SideBtn" TargetType="Button">
      <Setter Property="Background"   Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground"   Value="{StaticResource AccentBrush}"/>
      <Setter Property="FontFamily"   Value="{StaticResource FontPoppins}"/>
      <Setter Property="FontSize"     Value="20"/>
      <Setter Property="Width"        Value="48"/>
      <Setter Property="Height"       Value="48"/>
      <Setter Property="Cursor"       Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="12">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="{StaticResource TealSoftBrush}"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="TabBtn" TargetType="Button">
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0,0,0,3"/>
      <Setter Property="BorderBrush"     Value="Transparent"/>
      <Setter Property="Foreground"      Value="{StaticResource Ink3Brush}"/>
      <Setter Property="FontFamily"      Value="{StaticResource FontPoppins}"/>
      <Setter Property="FontSize"        Value="13"/>
      <Setter Property="Padding"         Value="16,12"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="TabBtnActive" TargetType="Button" BasedOn="{StaticResource TabBtn}">
      <Setter Property="BorderBrush"  Value="{StaticResource AccentBrush}"/>
      <Setter Property="Foreground"   Value="{StaticResource AccentBrush}"/>
      <Setter Property="FontWeight"   Value="SemiBold"/>
    </Style>

    <Style x:Key="FingerBtn" TargetType="Button">
      <Setter Property="Background"      Value="{StaticResource BgBrush}"/>
      <Setter Property="BorderThickness" Value="1.5"/>
      <Setter Property="BorderBrush"     Value="{StaticResource LineBrush}"/>
      <Setter Property="Foreground"      Value="{StaticResource InkBrush}"/>
      <Setter Property="FontFamily"      Value="{StaticResource FontPoppins}"/>
      <Setter Property="FontSize"        Value="12"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background"  Value="{StaticResource AccentSoftBrush}"/>
          <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="FingerBtnActive" TargetType="Button" BasedOn="{StaticResource FingerBtn}">
      <Setter Property="Background"  Value="{StaticResource AccentSoftBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
      <Setter Property="Foreground"  Value="{StaticResource AccentBrush}"/>
      <Setter Property="FontWeight"  Value="SemiBold"/>
    </Style>

    <Style x:Key="FormLabel" TargetType="TextBlock">
      <Setter Property="FontFamily"  Value="{StaticResource FontPoppins}"/>
      <Setter Property="FontSize"    Value="11"/>
      <Setter Property="FontWeight"  Value="SemiBold"/>
      <Setter Property="Foreground"  Value="{StaticResource Ink3Brush}"/>
      <Setter Property="Margin"      Value="0,0,0,4"/>
    </Style>

    <Style x:Key="FormValue" TargetType="TextBlock">
      <Setter Property="FontFamily"  Value="{StaticResource FontPoppins}"/>
      <Setter Property="FontSize"    Value="14"/>
      <Setter Property="Foreground"  Value="{StaticResource InkBrush}"/>
      <Setter Property="Margin"      Value="0,0,0,16"/>
    </Style>
  </Window.Resources>

  <Grid>
    <Viewbox Stretch="Uniform">
      <Grid Width="1366" Height="768">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="88"/>
          <ColumnDefinition/>
        </Grid.ColumnDefinitions>

    <!-- Sidebar -->
    <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
            Effect="{StaticResource ShadowCard}">
      <Grid>
        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,20,0,0">
          <!-- Brand circle -->
          <Border Width="44" Height="44" CornerRadius="12" Margin="0,0,0,16">
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#616EB3" Offset="0"/>
                <GradientStop Color="#383C6F" Offset="1"/>
              </LinearGradientBrush>
            </Border.Background>
            <TextBlock Text="R" FontFamily="{StaticResource FontPoppins}" FontWeight="Bold"
                       FontSize="20" Foreground="White"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
        </StackPanel>

        <Button Style="{StaticResource SideBtn}" Content="✕" VerticalAlignment="Bottom"
                Margin="0,0,0,20" HorizontalAlignment="Center"
                Click="BtnCerrar_Click" ToolTip="Cerrar panel"/>
      </Grid>
    </Border>

    <!-- Main area -->
    <Grid Grid.Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="72"/>
        <RowDefinition/>
      </Grid.RowDefinitions>

      <!-- Header -->
      <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
              BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1">
        <Grid Margin="32,0">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="Enrolador" FontFamily="{StaticResource FontPoppins}"
                       FontWeight="Bold" FontSize="20" Foreground="{StaticResource InkBrush}"
                       VerticalAlignment="Center"/>
            <Border x:Name="pillWorker" Background="{StaticResource AccentSoftBrush}"
                    CornerRadius="999" Padding="12,4" Margin="16,0,0,0"
                    VerticalAlignment="Center" Visibility="Collapsed">
              <TextBlock x:Name="lblWorkerPill" FontFamily="{StaticResource FontPoppins}"
                         FontSize="12" FontWeight="SemiBold"
                         Foreground="{StaticResource AccentBrush}"/>
            </Border>
          </StackPanel>

          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
            <Border Background="{StaticResource BgBrush}"
                    BorderBrush="{StaticResource LineBrush}" BorderThickness="1.5"
                    CornerRadius="8" Padding="12,6" Width="260">
              <Grid>
                <TextBlock x:Name="lblHintBusqueda" Text="Ingresa RUT y presiona Enter..."
                           Foreground="{StaticResource Ink3Brush}"
                           FontFamily="{StaticResource FontPoppins}" FontSize="13"
                           VerticalAlignment="Center" IsHitTestVisible="False"/>
                <TextBox x:Name="txtBusqueda" Background="Transparent" BorderThickness="0"
                         FontFamily="{StaticResource FontPoppins}" FontSize="13"
                         Foreground="{StaticResource InkBrush}"
                         TextChanged="TxtBusqueda_TextChanged"
                         KeyDown="TxtBusqueda_KeyDown"
                         VerticalAlignment="Center"/>
              </Grid>
            </Border>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Content area -->
      <Grid Grid.Row="1">

        <!-- Person list -->
        <ScrollViewer x:Name="scrollPersonas" VerticalScrollBarVisibility="Auto"
                      Padding="32,20">
          <StackPanel x:Name="panelLista"/>
        </ScrollViewer>

        <!-- Worker detail (Collapsed until person selected) -->
        <Grid x:Name="gridDetalle" Visibility="Collapsed">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
          </Grid.RowDefinitions>

          <!-- Worker card -->
          <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                  BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1"
                  Padding="32,16">
            <Grid>
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="48" Height="48" CornerRadius="10" Margin="0,0,14,0">
                  <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                      <GradientStop Color="#616EB3" Offset="0"/>
                      <GradientStop Color="#3F4690" Offset="1"/>
                    </LinearGradientBrush>
                  </Border.Background>
                  <TextBlock x:Name="lblAvatar" FontFamily="{StaticResource FontPoppins}"
                             FontWeight="Bold" FontSize="16" Foreground="White"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                  <TextBlock x:Name="lblNombreDetalle"
                             FontFamily="{StaticResource FontPoppins}"
                             FontWeight="Bold" FontSize="18"
                             Foreground="{StaticResource InkBrush}"/>
                  <TextBlock x:Name="lblRutDetalle" Style="{StaticResource TextSubtitle}"
                             Margin="0,3,0,0"/>
                </StackPanel>
              </StackPanel>

              <Button Content="← Lista" Style="{StaticResource BtnSecondary}"
                      HorizontalAlignment="Right" VerticalAlignment="Center"
                      Click="BtnVolver_Click"/>
            </Grid>
          </Border>

          <!-- Tab bar -->
          <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                  BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="16,0,0,0">
              <Button x:Name="btnTab0" Content="Datos generales"
                      Style="{StaticResource TabBtnActive}" Tag="0" Click="BtnTab_Click"/>
              <Button x:Name="btnTab1" Content="Asistencia"
                      Style="{StaticResource TabBtn}" Tag="1" Click="BtnTab_Click"/>
              <Button x:Name="btnTab2" Content="Huellas"
                      Style="{StaticResource TabBtn}" Tag="2" Click="BtnTab_Click"/>
              <Button x:Name="btnTab3" Content="Comidas"
                      Style="{StaticResource TabBtn}" Tag="3" Click="BtnTab_Click"/>
              <Button x:Name="btnTab4" Content="Relojes"
                      Style="{StaticResource TabBtn}" Tag="4" Click="BtnTab_Click"/>
            </StackPanel>
          </Border>

          <!-- Tab content -->
          <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                        Padding="32,24">
            <Grid>

              <!-- Tab 0: Datos generales -->
              <Grid x:Name="tabDatos">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="2*"/>
                  <ColumnDefinition Width="2*"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,24,0">
                  <TextBlock Style="{StaticResource FormLabel}" Text="NOMBRE COMPLETO"/>
                  <TextBlock x:Name="lblDatNombre" Style="{StaticResource FormValue}"/>
                  <TextBlock Style="{StaticResource FormLabel}" Text="RUT"/>
                  <TextBlock x:Name="lblDatRut" Style="{StaticResource FormValue}"/>
                  <TextBlock Style="{StaticResource FormLabel}" Text="CORREO ELECTRÓNICO"/>
                  <TextBlock x:Name="lblDatCorreo" Style="{StaticResource FormValue}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,24,0">
                  <TextBlock Style="{StaticResource FormLabel}" Text="PUESTO"/>
                  <TextBlock x:Name="lblDatPuesto" Style="{StaticResource FormValue}"/>
                  <TextBlock Style="{StaticResource FormLabel}" Text="CENTRO DE COSTO"/>
                  <TextBlock x:Name="lblDatCentro" Style="{StaticResource FormValue}"/>
                  <TextBlock Style="{StaticResource FormLabel}" Text="ACTIVO DESDE"/>
                  <TextBlock x:Name="lblDatActivo" Style="{StaticResource FormValue}"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                  <TextBlock Style="{StaticResource FormLabel}" Text="PERMISOS"/>
                  <CheckBox x:Name="chkHabilitada" Content="Habilitada"
                            IsEnabled="False" Margin="0,0,0,8"
                            FontFamily="{StaticResource FontPoppins}" FontSize="13"
                            Foreground="{StaticResource InkBrush}"/>
                  <CheckBox x:Name="chkEnrolar" Content="Puede enrolar"
                            IsEnabled="False" Margin="0,0,0,8"
                            FontFamily="{StaticResource FontPoppins}" FontSize="13"
                            Foreground="{StaticResource InkBrush}"/>
                  <CheckBox x:Name="chkAsistencia" Content="Registra asistencia"
                            IsEnabled="False"
                            FontFamily="{StaticResource FontPoppins}" FontSize="13"
                            Foreground="{StaticResource InkBrush}"/>
                </StackPanel>
              </Grid>

              <!-- Tab 1: Asistencia -->
              <Grid x:Name="tabAsistencia" Visibility="Collapsed">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                  <TextBlock Text="Últimos 30 días" Style="{StaticResource TextSubtitle}"
                             VerticalAlignment="Center" Margin="0,0,16,0"/>
                </StackPanel>

                <DataGrid x:Name="dgMarcas" Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          BorderThickness="1"
                          BorderBrush="{StaticResource LineBrush}"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{StaticResource LineBrush}"
                          RowBackground="{StaticResource SurfaceBrush}"
                          AlternatingRowBackground="{StaticResource BgBrush}"
                          FontFamily="{StaticResource FontPoppins}"
                          FontSize="13">
                  <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                      <Setter Property="Background"  Value="{StaticResource BgBrush}"/>
                      <Setter Property="Foreground"  Value="{StaticResource Ink3Brush}"/>
                      <Setter Property="FontWeight"  Value="SemiBold"/>
                      <Setter Property="FontSize"    Value="11"/>
                      <Setter Property="Padding"     Value="12,8"/>
                      <Setter Property="BorderThickness" Value="0,0,0,1"/>
                      <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
                    </Style>
                  </DataGrid.ColumnHeaderStyle>
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="FECHA Y HORA"  Binding="{Binding FechaHora}" Width="160"/>
                    <DataGridTextColumn Header="TIPO"          Binding="{Binding TipoMarca}"  Width="140"/>
                    <DataGridTextColumn Header="RELOJ"         Binding="{Binding Reloj}"       Width="*"/>
                    <DataGridTextColumn Header="INCIDENCIA"    Binding="{Binding Incidencia}"  Width="200"/>
                  </DataGrid.Columns>
                </DataGrid>
              </Grid>

              <!-- Tab 2: Huellas -->
              <Grid x:Name="tabHuellas" Visibility="Collapsed">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Registro de Huellas Digitales"
                           FontFamily="{StaticResource FontPoppins}" FontWeight="SemiBold"
                           FontSize="16" Foreground="{StaticResource InkBrush}"
                           Margin="0,0,0,20"/>

                <Grid Grid.Row="1">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>

                  <!-- Selector de dedo -->
                  <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource FormLabel}" Text="MANO DERECHA" Margin="0,0,0,6"/>
                    <Button x:Name="btnDedo1"  Content="Pulgar D"  Tag="1"  Height="34" Margin="0,0,0,4"  Style="{StaticResource FingerBtn}" Click="BtnDedo_Click"/>
                    <Button x:Name="btnDedo2"  Content="Índice D"  Tag="2"  Height="34" Margin="0,0,0,4"  Style="{StaticResource FingerBtn}" Click="BtnDedo_Click"/>
                    <Button x:Name="btnDedo3"  Content="Medio D"   Tag="3"  Height="34" Margin="0,0,0,4"  Style="{StaticResource FingerBtn}" Click="BtnDedo_Click"/>
                    <Button x:Name="btnDedo4"  Content="Anular D"  Tag="4"  Height="34" Margin="0,0,0,4"  Style="{StaticResource FingerBtn}" Click="BtnDedo_Click"/>
                    <Button x:Name="btnDedo5"  Content="Meñique D" Tag="5"  Height="34" Margin="0,0,0,16" Style="{StaticResource FingerBtn}" Click="BtnDedo_Click"/>
                    <TextBlock Style="{StaticResource FormLabel}" Text="MANO IZQUIERDA" Margin="0,0,0,6"/>
                    <Button x:Name="btnDedo6"  Content="Pulgar I"  Tag="6"  Height="34" Margin="0,0,0,4"  Style="{StaticResource FingerBtn}" Click="BtnDedo_Click"/>
                    <Button x:Name="btnDedo7"  Content="Índice I"  Tag="7"  Height="34" Margin="0,0,0,4"  Style="{StaticResource FingerBtn}" Click="BtnDedo_Click"/>
                    <Button x:Name="btnDedo8"  Content="Medio I"   Tag="8"  Height="34" Margin="0,0,0,4"  Style="{StaticResource FingerBtn}" Click="BtnDedo_Click"/>
                    <Button x:Name="btnDedo9"  Content="Anular I"  Tag="9"  Height="34" Margin="0,0,0,4"  Style="{StaticResource FingerBtn}" Click="BtnDedo_Click"/>
                    <Button x:Name="btnDedo10" Content="Meñique I" Tag="10" Height="34"                   Style="{StaticResource FingerBtn}" Click="BtnDedo_Click"/>
                  </StackPanel>

                  <!-- Panel derecho: EnrollmentControl + estado -->
                  <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}"
                          CornerRadius="12" Effect="{StaticResource ShadowCard}">
                    <StackPanel>
                      <TextBlock x:Name="lblEnrollStatus"
                                 FontFamily="{StaticResource FontPoppins}" FontSize="13"
                                 Foreground="{StaticResource Ink3Brush}"
                                 TextWrapping="Wrap" Margin="16,12,16,4"
                                 Text="Selecciona un dedo para comenzar el enrolamiento."/>
                      <Button x:Name="btnReiniciarEnroll" Content="Reiniciar"
                              Style="{StaticResource BtnSecondary}"
                              Margin="16,8,16,16" HorizontalAlignment="Left"
                              Click="BtnReiniciarEnroll_Click"/>
                    </StackPanel>
                  </Border>
                </Grid>
              </Grid>

              <!-- Tab 3: Comidas -->
              <Grid x:Name="tabComidas" Visibility="Collapsed">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="TIPOS DE COMIDA HABILITADOS"
                           Style="{StaticResource TextEyebrow}" Margin="0,0,0,16"/>
                <ItemsControl Grid.Row="1" x:Name="listaTiposComida">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{StaticResource SurfaceBrush}"
                              BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                              CornerRadius="{StaticResource RadiusInput}"
                              Padding="16,12" Margin="0,0,0,8">
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                          </Grid.ColumnDefinitions>
                          <CheckBox Grid.Column="0" IsChecked="{Binding Habilitado}"
                                    IsEnabled="False" VerticalAlignment="Center" Margin="0,0,14,0"/>
                          <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Nombre}" FontFamily="{StaticResource FontPoppins}"
                                       FontWeight="SemiBold" FontSize="14"
                                       Foreground="{StaticResource InkBrush}"/>
                            <TextBlock Text="{Binding Horario}" Style="{StaticResource TextHint}"/>
                          </StackPanel>
                          <Border Grid.Column="2" CornerRadius="{StaticResource RadiusBadge}"
                                  Padding="10,4" Background="{StaticResource AmberSoftBrush}">
                            <TextBlock Text="{Binding Valor}" FontFamily="{StaticResource FontPoppins}"
                                       FontWeight="SemiBold" FontSize="12"
                                       Foreground="{StaticResource AmberBrush}"/>
                          </Border>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Grid>

              <!-- Tab 4: Relojes -->
              <Grid x:Name="tabRelojes" Visibility="Collapsed">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="RELOJES ASIGNADOS"
                           Style="{StaticResource TextEyebrow}" Margin="0,0,0,16"/>
                <ItemsControl Grid.Row="1" x:Name="listaRelojes">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{StaticResource SurfaceBrush}"
                              BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                              CornerRadius="{StaticResource RadiusInput}"
                              Padding="16,12" Margin="0,0,0,8">
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition/>
                          </Grid.ColumnDefinitions>
                          <TextBlock Grid.Column="0" Text="{Binding Id}" Style="{StaticResource TextHint}"
                                     FontSize="10" VerticalAlignment="Center" Margin="0,0,14,0" Width="32"/>
                          <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Nombre}" FontFamily="{StaticResource FontPoppins}"
                                       FontWeight="SemiBold" FontSize="14"
                                       Foreground="{StaticResource InkBrush}"/>
                            <TextBlock Text="{Binding Ubicacion}" Style="{StaticResource TextHint}"/>
                          </StackPanel>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Grid>

            </Grid>
          </ScrollViewer>
        </Grid>

      </Grid>
    </Grid>
      </Grid>
    </Viewbox>
    <!-- ecHost fuera del Viewbox: Win32-visible para que DPFP SDK funcione -->
    <WindowsFormsHost x:Name="ecHost" Width="495" Height="314"
                      HorizontalAlignment="Left" VerticalAlignment="Top"
                      Margin="-1000,-1000,0,0"/>
  </Grid>
</Window>
