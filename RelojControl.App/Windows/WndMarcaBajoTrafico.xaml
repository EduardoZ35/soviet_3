<Window x:Class="RelojControl.Windows.WndMarcaBajoTrafico"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:RelojControl.Controls"
        WindowStyle="None" ResizeMode="NoResize" WindowState="Maximized" Topmost="True"
        Background="{StaticResource BgBrush}"
        KeyDown="Window_KeyDown">

  <Window.Resources>
    <Style x:Key="SentidoBtn" TargetType="Button">
      <Setter Property="Background"      Value="{StaticResource SurfaceBrush}"/>
      <Setter Property="BorderThickness" Value="0,0,5,0"/>
      <Setter Property="Padding"         Value="22,18"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Effect"          Value="{StaticResource ShadowCard}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="18"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="RenderTransform">
            <Setter.Value><TranslateTransform Y="-3"/></Setter.Value>
          </Setter>
        </Trigger>
      </Style.Triggers>
    </Style>
  </Window.Resources>

  <Grid>
    <Viewbox Stretch="Uniform">
      <Grid Width="768" Height="1366">
        <Grid.RowDefinitions>
          <RowDefinition Height="280"/>
          <RowDefinition/>
        </Grid.RowDefinitions>

        <ctrl:RailControl x:Name="rail" Grid.Row="0"/>

        <Grid Grid.Row="1" Background="{StaticResource BgBrush}">

      <ctrl:NotifOverlay x:Name="notif" Panel.ZIndex="100"/>

      <!-- IngresoRut -->
      <Grid x:Name="panelRut" Margin="40,48,40,40">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="MARCA TU ASISTENCIA"
                   FontFamily="{StaticResource FontPoppins}" FontSize="15" FontWeight="Bold"
                   Foreground="{StaticResource Ink3Brush}" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="1" Text="Ingresa tu RUT"
                   FontFamily="{StaticResource FontPoppins}" FontWeight="Bold" FontSize="40"
                   Foreground="{StaticResource InkBrush}" Margin="0,0,0,24"/>

        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource LineBrush}" BorderThickness="1.5"
                CornerRadius="10" Padding="20,14" Margin="0,0,0,20"
                Effect="{StaticResource ShadowCard}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="lblRutDisplay" Grid.Column="0"
                       FontFamily="{StaticResource FontManrope}" FontWeight="ExtraBold" FontSize="42"
                       Foreground="{StaticResource InkBrush}" VerticalAlignment="Center"/>
            <Rectangle x:Name="caret" Grid.Column="1" Width="3" Fill="{StaticResource AccentBrush}"
                       Height="42" VerticalAlignment="Center" Margin="4,0,0,0">
              <Rectangle.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                  <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever">
                      <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                       From="1" To="0" Duration="0:0:0.6" AutoReverse="True"/>
                    </Storyboard>
                  </BeginStoryboard>
                </EventTrigger>
              </Rectangle.Triggers>
            </Rectangle>
          </Grid>
        </Border>

        <ctrl:NumericKeypad x:Name="keypad" Grid.Row="3" KeyPressed="Keypad_KeyPressed"/>
      </Grid>

      <!-- VerificandoHuella -->
      <Grid x:Name="panelHuella" Margin="40,48,40,40" Visibility="Collapsed">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                CornerRadius="18" Padding="20,16"
                Effect="{StaticResource ShadowCard}" Margin="0,0,0,24">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Width="56" Height="56" CornerRadius="10" Margin="0,0,14,0">
              <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                  <GradientStop Color="#616EB3" Offset="0"/>
                  <GradientStop Color="#3F4690" Offset="1"/>
                </LinearGradientBrush>
              </Border.Background>
              <TextBlock x:Name="lblAvatar" FontFamily="{StaticResource FontPoppins}" FontWeight="Bold"
                         FontSize="18" Foreground="White" HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
            </Border>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
              <TextBlock x:Name="lblNombre" FontFamily="{StaticResource FontPoppins}" FontWeight="Bold"
                         FontSize="18" Foreground="{StaticResource InkBrush}"/>
              <TextBlock x:Name="lblRutCard" Style="{StaticResource TextSubtitle}" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
              <TextBlock Text="ÚLTIMA MARCA" FontFamily="{StaticResource FontPoppins}" FontSize="11"
                         FontWeight="Bold" Foreground="{StaticResource Ink3Brush}" HorizontalAlignment="Right"/>
              <TextBlock x:Name="lblUltimaMarca" Style="{StaticResource TextHint}"
                         HorizontalAlignment="Right" Margin="0,4,0,0"/>
            </StackPanel>
          </Grid>
        </Border>

        <Border Grid.Row="1" CornerRadius="999" Padding="16,8"
                HorizontalAlignment="Left" Margin="0,0,0,32"
                Background="{StaticResource TealSoftBrush}">
          <TextBlock x:Name="lblSentido" Text="Jornada · Inicio"
                     FontFamily="{StaticResource FontPoppins}" FontWeight="SemiBold" FontSize="14"
                     Foreground="{StaticResource TealBrush}"/>
        </Border>

        <ctrl:FingerprintRing x:Name="fpRing" Grid.Row="2"
                              HorizontalAlignment="Center" Margin="0,0,0,16"/>

        <TextBlock Grid.Row="3" Text="Verificando huella..."
                   FontFamily="{StaticResource FontPoppins}" FontWeight="SemiBold" FontSize="16"
                   Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center"/>

        <Button Grid.Row="4" Content="← Volver" Style="{StaticResource BtnSecondary}"
                HorizontalAlignment="Left" Click="BtnVolver_Click"/>
      </Grid>

      <!-- SeleccionSentido -->
      <Grid x:Name="panelSentido" Margin="40,48,40,40" Visibility="Collapsed">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Marca tu jornada"
                   FontFamily="{StaticResource FontPoppins}" FontWeight="Bold" FontSize="28"
                   Foreground="{StaticResource InkBrush}" Margin="0,0,0,24"/>
        <StackPanel Grid.Row="1">
          <Button Tag="Entrada" Click="BtnSentido_Click"
                  Style="{StaticResource SentidoBtn}" BorderBrush="{StaticResource TealBrush}"
                  Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
              <Border Width="56" Height="56" CornerRadius="10"
                      Background="{StaticResource TealSoftBrush}" Margin="0,0,16,0">
                <Viewbox Width="30" Height="30" HorizontalAlignment="Center" VerticalAlignment="Center">
                  <Canvas Width="24" Height="24">
                    <Path Stroke="{StaticResource TealBrush}" StrokeThickness="2"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                          Data="M14 4 h4 a2 2 0 0 1 2 2 v12 a2 2 0 0 1 -2 2 h-4 M3 12 h11 M9 7 l5 5 l-5 5"/>
                  </Canvas>
                </Viewbox>
              </Border>
              <StackPanel VerticalAlignment="Center">
                <TextBlock Text="ENTRADA" FontFamily="{StaticResource FontPoppins}" FontWeight="Bold"
                           FontSize="14" Foreground="{StaticResource TealBrush}"/>
                <TextBlock Text="Inicio de jornada" Style="{StaticResource TextSubtitle}" FontSize="14.5" Margin="0,4,0,0"/>
              </StackPanel>
            </StackPanel>
          </Button>
          <Button Tag="Salida" Click="BtnSentido_Click"
                  Style="{StaticResource SentidoBtn}" BorderBrush="{StaticResource CoralBrush}">
            <StackPanel Orientation="Horizontal">
              <Border Width="56" Height="56" CornerRadius="10"
                      Background="{StaticResource CoralSoftBrush}" Margin="0,0,16,0">
                <Viewbox Width="30" Height="30" HorizontalAlignment="Center" VerticalAlignment="Center">
                  <Canvas Width="24" Height="24">
                    <Path Stroke="{StaticResource CoralBrush}" StrokeThickness="2"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                          Data="M10 4 H6 a2 2 0 0 0 -2 2 v12 a2 2 0 0 0 2 2 h4 M21 12 H10 M16 7 l5 5 l-5 5"/>
                  </Canvas>
                </Viewbox>
              </Border>
              <StackPanel VerticalAlignment="Center">
                <TextBlock Text="SALIDA" FontFamily="{StaticResource FontPoppins}" FontWeight="Bold"
                           FontSize="14" Foreground="{StaticResource CoralBrush}"/>
                <TextBlock Text="Término de jornada" Style="{StaticResource TextSubtitle}" FontSize="14.5" Margin="0,4,0,0"/>
              </StackPanel>
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>

      <!-- Exito -->
      <Grid x:Name="panelExito" Visibility="Collapsed">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
          <ctrl:ResultBadge Kind="Success" HorizontalAlignment="Center" Margin="0,0,0,20"/>
          <TextBlock Text="¡Marca registrada!"
                     FontFamily="{StaticResource FontPoppins}" FontWeight="Bold" FontSize="32"
                     Foreground="{StaticResource InkBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
          <TextBlock x:Name="lblNombreExito" Style="{StaticResource TextSubtitle}"
                     HorizontalAlignment="Center" FontSize="18" Margin="0,0,0,16"/>
          <Border CornerRadius="999" Padding="20,10" HorizontalAlignment="Center"
                  Background="{StaticResource TealSoftBrush}" Margin="0,0,0,16">
            <TextBlock x:Name="lblSentidoExito" FontFamily="{StaticResource FontPoppins}"
                       FontWeight="SemiBold" FontSize="16" Foreground="{StaticResource TealBrush}"/>
          </Border>
          <TextBlock Text="Volviendo al inicio en 5s..."
                     Style="{StaticResource TextHint}" HorizontalAlignment="Center"/>
        </StackPanel>
      </Grid>

      <!-- Error -->
      <Grid x:Name="panelError" Visibility="Collapsed">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
          <ctrl:ResultBadge Kind="Error" HorizontalAlignment="Center" Margin="0,0,0,20"/>
          <TextBlock Text="No se pudo registrar"
                     FontFamily="{StaticResource FontPoppins}" FontWeight="Bold" FontSize="28"
                     Foreground="{StaticResource CoralBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
          <TextBlock x:Name="lblMensajeError" Style="{StaticResource TextSubtitle}"
                     HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,16"/>
          <Button Content="Intentar de nuevo" Style="{StaticResource BtnAccent}"
                  HorizontalAlignment="Center" Click="BtnReintentar_Click"/>
        </StackPanel>
      </Grid>

        </Grid>
      </Grid>
    </Viewbox>
    <!-- fpHost fuera del Viewbox: Win32-visible para que DPFP SDK funcione -->
    <WindowsFormsHost x:Name="fpHost" Width="300" Height="200"
                      HorizontalAlignment="Left" VerticalAlignment="Top"
                      Margin="-400,-300,0,0"/>
  </Grid>
</Window>
