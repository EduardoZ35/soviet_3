<Window x:Class="RelojControl.Windows.WndPanelControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:RelojControl.Controls"
        WindowStyle="SingleBorderWindow" ResizeMode="CanResize"
        Width="1280" Height="800" WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}">
  <Grid>
    <Viewbox Stretch="Uniform">
      <Grid Width="1366" Height="768">
        <DockPanel>
      <!-- Header -->
      <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}"
              BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1" Height="74">
        <Grid Margin="28,0">
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Panel de Control · Administración de Usuarios"
                       FontFamily="{StaticResource FontPoppins}" FontWeight="Bold" FontSize="18"
                       Foreground="{StaticResource InkBrush}"/>
            <TextBlock Text="Estación RR.HH. · Reloj Control"
                       FontFamily="{StaticResource FontPoppins}" FontSize="12"
                       Foreground="{StaticResource Ink3Brush}"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
            <!-- Chip operador -->
            <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="999"
                    Padding="10,6" Margin="0,0,12,0" VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal">
                <Border Width="34" Height="34" CornerRadius="17" Margin="0,0,8,0">
                  <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                      <GradientStop Color="#616EB3" Offset="0"/>
                      <GradientStop Color="#3F4690" Offset="1"/>
                    </LinearGradientBrush>
                  </Border.Background>
                  <TextBlock x:Name="lblChipIniciales" Text="AD"
                             FontFamily="{StaticResource FontManrope}" FontWeight="Bold"
                             FontSize="13" Foreground="White"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Administrador" FontFamily="{StaticResource FontPoppins}"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
              </StackPanel>
            </Border>
            <!-- Salir -->
            <Button Content="Salir" Click="BtnCerrar_Click"
                    Background="{StaticResource Surface2Brush}"
                    BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                    Foreground="{StaticResource Ink2Brush}"
                    FontFamily="{StaticResource FontPoppins}" FontWeight="SemiBold" FontSize="14"
                    Padding="18,0" Height="44" Cursor="Hand">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border Background="{TemplateBinding Background}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}"
                          CornerRadius="11" Padding="{TemplateBinding Padding}">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                </ControlTemplate>
              </Button.Template>
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Sidebar -->
      <Border DockPanel.Dock="Left" Width="156" Background="{StaticResource RailBrush}">
        <DockPanel LastChildFill="True">
          <Image DockPanel.Dock="Top"
                 Source="pack://application:,,,/RelojControl;component/Assets/logo-rflex-white.png"
                 Height="36" Margin="18,28,18,24" HorizontalAlignment="Left" VerticalAlignment="Top"
                 Stretch="Uniform" StretchDirection="Both"
                 RenderOptions.BitmapScalingMode="HighQuality"/>
          <StackPanel DockPanel.Dock="Top" Margin="10,0">
            <Button x:Name="btnNavEnrolar" Click="BtnEnrolamiento_Click"
                    BorderThickness="0" FocusVisualStyle="{x:Null}"
                    Height="72" Margin="0,0,0,10" Cursor="Hand">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border x:Name="bg" CornerRadius="15" Background="White">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                </ControlTemplate>
              </Button.Template>
              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Viewbox Width="28" Height="28" HorizontalAlignment="Center">
                  <Canvas Width="24" Height="24">
                    <Path Stroke="{StaticResource AccentDeepBrush}" StrokeThickness="1.5"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                          Fill="Transparent" Data="M12 10a2 2 0 0 0-2 2c0 1.02-.1 2.51-.26 4"/>
                    <Path Stroke="{StaticResource AccentDeepBrush}" StrokeThickness="1.5"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                          Fill="Transparent" Data="M14 13.12c0 2.38 0 6.38-1 8.88"/>
                    <Path Stroke="{StaticResource AccentDeepBrush}" StrokeThickness="1.5"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                          Fill="Transparent" Data="M17.29 21.02c.12-.6.43-2.3.5-3.02"/>
                    <Path Stroke="{StaticResource AccentDeepBrush}" StrokeThickness="1.5"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                          Fill="Transparent" Data="M2 12a10 10 0 0 1 18-6"/>
                    <Path Stroke="{StaticResource AccentDeepBrush}" StrokeThickness="1.5"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                          Fill="Transparent" Data="M2 16h.01"/>
                    <Path Stroke="{StaticResource AccentDeepBrush}" StrokeThickness="1.5"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                          Fill="Transparent" Data="M21.8 16c.2-2 .131-5.354 0-6"/>
                    <Path Stroke="{StaticResource AccentDeepBrush}" StrokeThickness="1.5"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                          Fill="Transparent" Data="M5 19.5C5.5 18 6 15 6 12a6 6 0 0 1 .34-2"/>
                    <Path Stroke="{StaticResource AccentDeepBrush}" StrokeThickness="1.5"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                          Fill="Transparent" Data="M8.65 22c.21-.66.45-1.32.57-2"/>
                    <Path Stroke="{StaticResource AccentDeepBrush}" StrokeThickness="1.5"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                          Fill="Transparent" Data="M9 6.8a6 6 0 0 1 9 5.2v2"/>
                  </Canvas>
                </Viewbox>
                <TextBlock Text="Enrolar" Foreground="{StaticResource AccentDeepBrush}"
                           FontFamily="{StaticResource FontPoppins}" FontSize="13" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
              </StackPanel>
            </Button>
          </StackPanel>
          <Grid/>
        </DockPanel>
      </Border>

      <!-- Main content -->
      <ContentControl x:Name="mainContent" Background="{StaticResource BgBrush}"
                      HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
        <ContentControl.Content>
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border Width="64" Height="64" CornerRadius="20" HorizontalAlignment="Center"
                    Margin="0,0,0,14">
              <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                  <GradientStop Color="#ECEDFB" Offset="0"/>
                  <GradientStop Color="#D6D8F8" Offset="1"/>
                </LinearGradientBrush>
              </Border.Background>
              <Viewbox Width="28" Height="28">
                <Canvas Width="24" Height="24">
                  <Path Stroke="{StaticResource AccentBrush}" StrokeThickness="1.5"
                        StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                        Data="M12 12C14.2 12 16 10.2 16 8C16 5.8 14.2 4 12 4C9.8 4 8 5.8 8 8C8 10.2 9.8 12 12 12Z M5 20C5 16.4 8.1 14.4 12 14.4C15.9 14.4 19 16.4 19 20"/>
                </Canvas>
              </Viewbox>
            </Border>
            <TextBlock Text="Selecciona una opción del menú lateral"
                       FontFamily="{StaticResource FontPoppins}" FontSize="15"
                       Foreground="{StaticResource Ink3Brush}"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </ContentControl.Content>
      </ContentControl>
        </DockPanel>
      </Grid>
    </Viewbox>
    <WindowsFormsHost x:Name="ecHost" Width="495" Height="314"
                      HorizontalAlignment="Left" VerticalAlignment="Top"
                      Margin="-1000,-1000,0,0"/>
  </Grid>
</Window>
