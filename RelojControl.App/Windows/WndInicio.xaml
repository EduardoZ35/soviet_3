<Window x:Class="RelojControl.Windows.WndInicio"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="SingleBorderWindow" ResizeMode="CanResize"
        Width="1366" Height="768" WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}">
  <Window.Resources>
    <CornerRadius x:Key="RadiusInput">13</CornerRadius>
    <Style x:Key="PasswordInputBase" TargetType="PasswordBox">
      <Setter Property="FontFamily"      Value="{StaticResource FontPoppins}"/>
      <Setter Property="FontSize"        Value="14"/>
      <Setter Property="Foreground"      Value="{StaticResource InkBrush}"/>
      <Setter Property="Background"      Value="{StaticResource SurfaceBrush}"/>
      <Setter Property="BorderBrush"     Value="{StaticResource LineBrush}"/>
      <Setter Property="BorderThickness" Value="1.5"/>
      <Setter Property="Padding"         Value="12,8"/>
      <Setter Property="Height"          Value="54"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="PasswordBox">
            <Border x:Name="bd" Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="13">
              <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsFocused" Value="True">
                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>
  <Grid>
    <Viewbox Stretch="Uniform">
      <Grid Width="1366" Height="768">
        <Border>
          <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0.4,1">
              <GradientStop Color="#FF5A63A8" Offset="0"/>
              <GradientStop Color="#FF454B8F" Offset="0.55"/>
              <GradientStop Color="#FF383C6F" Offset="1"/>
            </LinearGradientBrush>
          </Border.Background>

    <DockPanel>
      <!-- TOP BAR -->
      <Grid DockPanel.Dock="Top" Margin="40,28,40,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Sync pill -->
        <Border Grid.Column="0" CornerRadius="999" Padding="10,7"
                Background="#33FFFFFF" BorderBrush="#44FFFFFF" BorderThickness="1"
                Effect="{x:Null}">
          <StackPanel Orientation="Horizontal">
            <Ellipse x:Name="syncDotInicio" Width="8" Height="8" Fill="#4ADE80" VerticalAlignment="Center"/>
            <TextBlock x:Name="lblSyncInicio" Text="Sincronizado · en línea"
                       FontFamily="{StaticResource FontPoppins}" FontSize="13.5" FontWeight="SemiBold"
                       Foreground="White" Margin="8,0,0,0"/>
          </StackPanel>
        </Border>

        <!-- Title -->
        <TextBlock x:Name="lblTituloReloj" Grid.Column="1" Text="Registro de Asistencia"
                   FontFamily="{StaticResource FontPoppins}" FontSize="16" FontWeight="Medium"
                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <!-- Clock -->
        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
          <TextBlock x:Name="lblHoraInicio"
                     FontFamily="{StaticResource FontManrope}" FontWeight="ExtraBold" FontSize="32"
                     Foreground="White" HorizontalAlignment="Right"/>
          <TextBlock x:Name="lblFechaInicio"
                     FontFamily="{StaticResource FontPoppins}" FontSize="12"
                     Foreground="#C7C6EE" HorizontalAlignment="Right"/>
        </StackPanel>
      </Grid>

      <!-- FOOTER -->
      <Image DockPanel.Dock="Bottom"
             Source="pack://application:,,,/RelojControl;component/Assets/logo-rflex-white.png"
             Height="34" HorizontalAlignment="Center" Margin="0,0,0,24"/>

      <!-- CARDS CENTER -->
      <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40,32">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="480"/>
          <ColumnDefinition Width="24"/>
          <ColumnDefinition Width="480"/>
        </Grid.ColumnDefinitions>

        <!-- Login card -->
        <Border x:Name="cardLogin" Grid.Column="0"
                Width="480" MinHeight="320"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="18" Padding="32"
                Effect="{StaticResource ShadowCard}" Visibility="Collapsed">
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
              <TextBlock Text="🔒" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
              <TextBlock Text="Iniciar sesión administrador"
                         FontFamily="{StaticResource FontPoppins}" FontWeight="Bold" FontSize="17"
                         Foreground="{StaticResource InkBrush}" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Margin="0,0,0,16">
              <TextBlock Text="Usuario" Style="{StaticResource TextHint}" Margin="0,0,0,6"/>
              <TextBox x:Name="txtUsuario" Style="{StaticResource InputBase}" Height="54" Margin="0,0,0,8"/>
              <TextBlock Text="Contraseña" Style="{StaticResource TextHint}" Margin="0,0,0,6"/>
              <PasswordBox x:Name="txtPass" Style="{StaticResource PasswordInputBase}"
                           KeyDown="TxtPass_KeyDown"/>
            </StackPanel>

            <Button Content="Iniciar sesión" Style="{StaticResource BtnAccent}"
                    Background="{StaticResource TealBrush}" Click="BtnLogin_Click"
                    HorizontalAlignment="Stretch"/>
          </StackPanel>
        </Border>

        <!-- Marca card -->
        <Border x:Name="cardMarca" Grid.Column="2"
                Width="480" MinHeight="320"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="18" Padding="32"
                Effect="{StaticResource ShadowCard}" Cursor="Hand"
                MouseLeftButtonUp="CardMarca_Click">
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Path x:Name="pathHuella"
                  Stroke="{StaticResource AccentDeepBrush}" StrokeThickness="5"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                  Width="64" Height="64" Stretch="Uniform"
                  HorizontalAlignment="Center" Margin="0,0,0,16"/>
            <TextBlock Text="Registrar marca"
                       FontFamily="{StaticResource FontPoppins}" FontWeight="Bold" FontSize="26"
                       Foreground="{StaticResource AccentDeepBrush}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>
      </Grid>
    </DockPanel>
        </Border>
      </Grid>
    </Viewbox>
  </Grid>
</Window>
