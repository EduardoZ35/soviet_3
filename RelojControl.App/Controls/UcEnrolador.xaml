<UserControl x:Class="RelojControl.Controls.UcEnrolador"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <UserControl.Resources>
    <Style x:Key="SideBtn" TargetType="Button">
      <Setter Property="Background"   Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground"   Value="{StaticResource AccentBrush}"/>
      <Setter Property="FontFamily"   Value="{StaticResource FontPoppins}"/>
      <Setter Property="FontSize"     Value="20"/>
      <Setter Property="Width"        Value="48"/>
      <Setter Property="Height"       Value="48"/>
      <Setter Property="Cursor"       Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="12">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="{StaticResource TealSoftBrush}"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="TabBtn" TargetType="Button">
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0,0,0,3"/>
      <Setter Property="BorderBrush"     Value="Transparent"/>
      <Setter Property="Foreground"      Value="{StaticResource Ink3Brush}"/>
      <Setter Property="FontFamily"      Value="{StaticResource FontPoppins}"/>
      <Setter Property="FontSize"        Value="13"/>
      <Setter Property="Padding"         Value="16,12"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="TabBtnActive" TargetType="Button" BasedOn="{StaticResource TabBtn}">
      <Setter Property="BorderBrush"  Value="{StaticResource AccentBrush}"/>
      <Setter Property="Foreground"   Value="{StaticResource AccentBrush}"/>
      <Setter Property="FontWeight"   Value="SemiBold"/>
    </Style>

    <Style x:Key="FingerBtn" TargetType="Button">
      <Setter Property="Background"      Value="{StaticResource BgBrush}"/>
      <Setter Property="BorderThickness" Value="1.5"/>
      <Setter Property="BorderBrush"     Value="{StaticResource LineBrush}"/>
      <Setter Property="Foreground"      Value="{StaticResource InkBrush}"/>
      <Setter Property="FontFamily"      Value="{StaticResource FontPoppins}"/>
      <Setter Property="FontSize"        Value="12"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background"  Value="{StaticResource AccentSoftBrush}"/>
          <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="FingerBtnActive" TargetType="Button" BasedOn="{StaticResource FingerBtn}">
      <Setter Property="Background"  Value="{StaticResource AccentSoftBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
      <Setter Property="Foreground"  Value="{StaticResource AccentBrush}"/>
      <Setter Property="FontWeight"  Value="SemiBold"/>
    </Style>

    <Style x:Key="FingerBtnEnrolled" TargetType="Button" BasedOn="{StaticResource FingerBtn}">
      <Setter Property="Background"  Value="{StaticResource OkSoftBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource OkBrush}"/>
      <Setter Property="Foreground"  Value="{StaticResource OkBrush}"/>
    </Style>

    <Style x:Key="FingerBtnEnrolledActive" TargetType="Button" BasedOn="{StaticResource FingerBtnEnrolled}">
      <Setter Property="FontWeight"  Value="SemiBold"/>
      <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <Style x:Key="FormLabel" TargetType="TextBlock">
      <Setter Property="FontFamily"  Value="{StaticResource FontPoppins}"/>
      <Setter Property="FontSize"    Value="12"/>
      <Setter Property="FontWeight"  Value="SemiBold"/>
      <Setter Property="Foreground"  Value="{StaticResource Ink2Brush}"/>
      <Setter Property="Margin"      Value="0,0,0,6"/>
    </Style>

    <Style x:Key="FormInput" TargetType="TextBox">
      <Setter Property="FontFamily"               Value="{StaticResource FontPoppins}"/>
      <Setter Property="FontSize"                 Value="14"/>
      <Setter Property="Foreground"               Value="{StaticResource InkBrush}"/>
      <Setter Property="Background"               Value="{StaticResource SurfaceBrush}"/>
      <Setter Property="BorderBrush"              Value="{StaticResource LineBrush}"/>
      <Setter Property="BorderThickness"          Value="1.5"/>
      <Setter Property="Height"                   Value="42"/>
      <Setter Property="Padding"                  Value="12,0"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="10">
              <ScrollViewer x:Name="PART_ContentHost"
                            Margin="{TemplateBinding Padding}"
                            VerticalAlignment="Center"
                            VerticalScrollBarVisibility="Hidden"
                            HorizontalScrollBarVisibility="Hidden"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="FormValue" TargetType="TextBlock">
      <Setter Property="FontFamily"  Value="{StaticResource FontPoppins}"/>
      <Setter Property="FontSize"    Value="14"/>
      <Setter Property="Foreground"  Value="{StaticResource InkBrush}"/>
      <Setter Property="Margin"      Value="0,0,0,16"/>
    </Style>

    <Style x:Key="AccentCheckBox" TargetType="CheckBox">
      <Setter Property="FontFamily"  Value="{StaticResource FontPoppins}"/>
      <Setter Property="FontSize"    Value="13"/>
      <Setter Property="Foreground"  Value="{StaticResource InkBrush}"/>
      <Setter Property="Margin"      Value="0,0,0,8"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="CheckBox">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <Border x:Name="box" Width="20" Height="20" CornerRadius="6"
                      BorderBrush="{StaticResource LineBrush}" BorderThickness="1.5"
                      Background="{StaticResource SurfaceBrush}" Margin="0,0,10,0">
                <Path x:Name="chk" Visibility="Collapsed"
                      Stroke="White" StrokeThickness="2.2"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      StrokeLineJoin="Round"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Data="M 3,9 L 8,14 L 17,5"/>
              </Border>
              <ContentPresenter VerticalAlignment="Center"/>
            </StackPanel>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="box" Property="Background"  Value="{StaticResource AccentBrush}"/>
                <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                <Setter TargetName="chk" Property="Visibility"  Value="Visible"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </UserControl.Resources>

  <Grid Width="1366" Height="768">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="88"/>
      <ColumnDefinition/>
    </Grid.ColumnDefinitions>

    <!-- Sidebar -->
    <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
            Effect="{StaticResource ShadowCard}"/>

    <!-- Main area -->
    <Grid Grid.Column="1">

      <!-- Content area -->
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- Search card -->
        <Border x:Name="searchCard" Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                CornerRadius="14" Padding="20,16" Margin="32,24,32,0"
                Effect="{StaticResource ShadowCard}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center">
              <TextBlock Text="Ingrese RUT del funcionario" FontFamily="{StaticResource FontPoppins}"
                         FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Ink3Brush}" Margin="0,0,0,5"/>
              <Border BorderBrush="{StaticResource LineBrush}" BorderThickness="1.5"
                      CornerRadius="10" Background="{StaticResource BgBrush}" Padding="12,0" Width="260">
                <Grid>
                  <TextBlock x:Name="lblHintBusqueda2" Text="12.345.678-9"
                             Foreground="{StaticResource Ink3Brush}"
                             FontFamily="{StaticResource FontPoppins}" FontSize="13"
                             VerticalAlignment="Center" IsHitTestVisible="False"/>
                  <TextBox x:Name="txtBusqueda2" Background="Transparent" BorderThickness="0"
                           Height="42" FontFamily="{StaticResource FontPoppins}" FontSize="13"
                           Foreground="{StaticResource InkBrush}" VerticalAlignment="Center"
                           TextChanged="TxtBusqueda_TextChanged2"
                           KeyDown="TxtBusqueda_KeyDown2"/>
                </Grid>
              </Border>
            </StackPanel>
            <Button Grid.Column="1" Content="🔍 Buscar" Height="42" Padding="18,0"
                    Background="{StaticResource AccentBrush}" Foreground="White"
                    FontFamily="{StaticResource FontPoppins}" FontWeight="SemiBold" FontSize="13"
                    Cursor="Hand" Click="BtnBuscar_Click" VerticalAlignment="Bottom" Margin="0,0,10,0">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                </ControlTemplate>
              </Button.Template>
            </Button>
            <Button Grid.Column="2" Content="✏ Limpiar" Height="42" Padding="16,0"
                    Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource Ink2Brush}"
                    BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                    FontFamily="{StaticResource FontPoppins}" FontSize="13"
                    Cursor="Hand" Click="BtnLimpiar_Click" VerticalAlignment="Bottom">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                </ControlTemplate>
              </Button.Template>
            </Button>
          </Grid>
        </Border>

        <!-- Person list -->
        <ScrollViewer x:Name="scrollPersonas" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Padding="32,20">
          <StackPanel x:Name="panelLista"/>
        </ScrollViewer>

        <!-- Empty state (visible until first search) -->
        <Border x:Name="emptyState" Grid.Row="1" Background="{StaticResource BgBrush}">
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border Width="96" Height="96" CornerRadius="24"
                    Background="{StaticResource AccentSoftBrush}"
                    HorizontalAlignment="Center" Margin="0,0,0,18">
              <Viewbox Width="44" Height="44">
                <Canvas Width="24" Height="24">
                  <Ellipse Canvas.Left="3" Canvas.Top="3" Width="16" Height="16"
                           Stroke="{StaticResource AccentBrush}" StrokeThickness="2" Fill="Transparent"/>
                  <Path Stroke="{StaticResource AccentBrush}" StrokeThickness="2"
                        StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                        Data="M 16.65,16.65 L 21,21"/>
                </Canvas>
              </Viewbox>
            </Border>
            <TextBlock Text="Busca un funcionario para comenzar"
                       FontFamily="{StaticResource FontPoppins}" FontWeight="Bold"
                       FontSize="20" Foreground="{StaticResource Ink2Brush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Ingresa el RUT en el buscador y presiona Enter"
                       FontFamily="{StaticResource FontPoppins}" FontSize="15"
                       Foreground="{StaticResource Ink3Brush}"
                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
          </StackPanel>
        </Border>

        <!-- Worker detail (Collapsed until person selected) -->
        <Grid x:Name="gridDetalle" Grid.Row="1" Visibility="Collapsed">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <!-- Worker card -->
          <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                  BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                  CornerRadius="14" Padding="20,16"
                  Effect="{StaticResource ShadowCard}"
                  Margin="32,16,32,0">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>

              <!-- Col 0: avatar -->
              <Border Grid.Column="0" Width="52" Height="52" CornerRadius="12" Margin="0,0,16,0">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#616EB3" Offset="0"/>
                    <GradientStop Color="#3F4690" Offset="1"/>
                  </LinearGradientBrush>
                </Border.Background>
                <TextBlock x:Name="lblAvatar" FontFamily="{StaticResource FontPoppins}"
                           FontWeight="Bold" FontSize="17" Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>

              <!-- Col 1: nombre + cargo -->
              <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="lblNombreDetalle"
                           FontFamily="{StaticResource FontPoppins}"
                           FontWeight="Bold" FontSize="17"
                           Foreground="{StaticResource InkBrush}"/>
                <TextBlock x:Name="lblCargoDetalle"
                           FontFamily="{StaticResource FontPoppins}"
                           FontSize="13" Foreground="{StaticResource Ink2Brush}"
                           Margin="0,4,0,0"/>
              </StackPanel>

              <!-- Col 2: RUT + estado pill -->
              <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                <TextBlock x:Name="lblRutDetalle"
                           FontFamily="{StaticResource FontPoppins}"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource Ink2Brush}"
                           HorizontalAlignment="Right"/>
                <Border x:Name="pillEstado" CornerRadius="999" Padding="10,4"
                        Background="{StaticResource OkSoftBrush}" Margin="0,5,0,0"
                        HorizontalAlignment="Right">
                  <TextBlock x:Name="lblEstado" Text="Activo"
                             FontFamily="{StaticResource FontPoppins}"
                             FontSize="11" FontWeight="SemiBold"
                             Foreground="{StaticResource OkBrush}"/>
                </Border>
              </StackPanel>
            </Grid>
          </Border>

          <!-- Stepper -->
          <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                  BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1"
                  Padding="0,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">

                <Button x:Name="btnTab0" Tag="0" Click="BtnTab_Click"
                        Background="Transparent" BorderThickness="0" Cursor="Hand" FocusVisualStyle="{x:Null}">
                  <StackPanel Orientation="Horizontal">
                    <Border x:Name="stepCircle0" Width="28" Height="28" CornerRadius="14" Margin="0,0,8,0"
                            Background="{StaticResource AccentBrush}" BorderThickness="0">
                      <TextBlock Text="1" Foreground="White" FontFamily="{StaticResource FontManrope}"
                                 FontWeight="Bold" FontSize="13"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="stepLabel0" Text="Datos generales"
                               FontFamily="{StaticResource FontPoppins}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"
                               Visibility="Visible"/>
                  </StackPanel>
                </Button>

                <Rectangle Width="24" Height="2" Fill="{StaticResource LineBrush}" VerticalAlignment="Center" Margin="4,0"/>

                <Button x:Name="btnTab1" Tag="1" Click="BtnTab_Click"
                        Background="Transparent" BorderThickness="0" Cursor="Hand" FocusVisualStyle="{x:Null}">
                  <StackPanel Orientation="Horizontal">
                    <Border x:Name="stepCircle1" Width="28" Height="28" CornerRadius="14" Margin="0,0,8,0"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource LineBrush}" BorderThickness="1.5">
                      <TextBlock Text="2" Foreground="{StaticResource Ink3Brush}" FontFamily="{StaticResource FontManrope}"
                                 FontWeight="Bold" FontSize="13"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="stepLabel1" Text="Asistencia"
                               FontFamily="{StaticResource FontPoppins}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource Ink3Brush}" VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                  </StackPanel>
                </Button>

                <Rectangle Width="24" Height="2" Fill="{StaticResource LineBrush}" VerticalAlignment="Center" Margin="4,0"/>

                <Button x:Name="btnTab2" Tag="2" Click="BtnTab_Click"
                        Background="Transparent" BorderThickness="0" Cursor="Hand" FocusVisualStyle="{x:Null}">
                  <StackPanel Orientation="Horizontal">
                    <Border x:Name="stepCircle2" Width="28" Height="28" CornerRadius="14" Margin="0,0,8,0"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource LineBrush}" BorderThickness="1.5">
                      <TextBlock Text="3" Foreground="{StaticResource Ink3Brush}" FontFamily="{StaticResource FontManrope}"
                                 FontWeight="Bold" FontSize="13"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="stepLabel2" Text="Huellas"
                               FontFamily="{StaticResource FontPoppins}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource Ink3Brush}" VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                  </StackPanel>
                </Button>

                <Rectangle Width="24" Height="2" Fill="{StaticResource LineBrush}" VerticalAlignment="Center" Margin="4,0"/>

                <Button x:Name="btnTab3" Tag="3" Click="BtnTab_Click"
                        Background="Transparent" BorderThickness="0" Cursor="Hand" FocusVisualStyle="{x:Null}">
                  <StackPanel Orientation="Horizontal">
                    <Border x:Name="stepCircle3" Width="28" Height="28" CornerRadius="14" Margin="0,0,8,0"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource LineBrush}" BorderThickness="1.5">
                      <TextBlock Text="4" Foreground="{StaticResource Ink3Brush}" FontFamily="{StaticResource FontManrope}"
                                 FontWeight="Bold" FontSize="13"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="stepLabel3" Text="Comidas"
                               FontFamily="{StaticResource FontPoppins}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource Ink3Brush}" VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                  </StackPanel>
                </Button>

                <Rectangle Width="24" Height="2" Fill="{StaticResource LineBrush}" VerticalAlignment="Center" Margin="4,0"/>

                <Button x:Name="btnTab4" Tag="4" Click="BtnTab_Click"
                        Background="Transparent" BorderThickness="0" Cursor="Hand" FocusVisualStyle="{x:Null}">
                  <StackPanel Orientation="Horizontal">
                    <Border x:Name="stepCircle4" Width="28" Height="28" CornerRadius="14" Margin="0,0,8,0"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource LineBrush}" BorderThickness="1.5">
                      <TextBlock Text="5" Foreground="{StaticResource Ink3Brush}" FontFamily="{StaticResource FontManrope}"
                                 FontWeight="Bold" FontSize="13"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="stepLabel4" Text="Relojes"
                               FontFamily="{StaticResource FontPoppins}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource Ink3Brush}" VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                  </StackPanel>
                </Button>

              </StackPanel>
          </Border>

          <!-- Tab content -->
          <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                        Padding="32,24">
            <Grid>

              <!-- Tab 0: Datos generales -->
              <Grid x:Name="tabDatos">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="320"/>
                  <ColumnDefinition Width="32"/>
                  <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <!-- Columna izquierda -->
                <StackPanel Grid.Column="0">
                  <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Nombre" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="txtDatNombre" Style="{StaticResource FormInput}"/>
                  </StackPanel>
                  <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Segundo nombre" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="txtDatSegNombre" Style="{StaticResource FormInput}"/>
                  </StackPanel>
                  <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Apellido paterno" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="txtDatApPat" Style="{StaticResource FormInput}"/>
                  </StackPanel>
                  <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Apellido materno" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="txtDatApMat" Style="{StaticResource FormInput}"/>
                  </StackPanel>
                  <StackPanel>
                    <TextBlock Text="Correo electrónico" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="txtDatCorreo" Style="{StaticResource FormInput}"/>
                  </StackPanel>
                </StackPanel>

                <!-- Columna derecha -->
                <StackPanel Grid.Column="2">
                  <TextBlock Text="Empresa" Style="{StaticResource FormLabel}"/>
                  <ComboBox x:Name="cmbDatEmpresa"
                            FontFamily="{StaticResource FontPoppins}" FontSize="14"
                            Height="42" BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1.5" Padding="12,0"
                            Background="{StaticResource SurfaceBrush}"
                            IsEnabled="False"/>
                </StackPanel>
              </Grid>

              <!-- Tab 1: Asistencia -->
              <Grid x:Name="tabAsistencia" Visibility="Collapsed">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                  <TextBlock Text="PERMISOS" Style="{StaticResource TextEyebrow}" Margin="0,0,0,10"/>
                  <CheckBox x:Name="chkHabilitada"  Content="Habilitada"
                            Style="{StaticResource AccentCheckBox}" IsEnabled="False"/>
                  <CheckBox x:Name="chkEnrolar"     Content="Puede enrolar"
                            Style="{StaticResource AccentCheckBox}" IsEnabled="False"/>
                  <CheckBox x:Name="chkAsistencia"  Content="Registra asistencia"
                            Style="{StaticResource AccentCheckBox}" IsEnabled="False"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
                  <TextBlock Text="Últimos 30 días" Style="{StaticResource TextSubtitle}"
                             VerticalAlignment="Center" Margin="0,0,16,0"/>
                </StackPanel>

                <DataGrid x:Name="dgMarcas" Grid.Row="2"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          BorderThickness="1"
                          BorderBrush="{StaticResource LineBrush}"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{StaticResource LineBrush}"
                          RowBackground="{StaticResource SurfaceBrush}"
                          AlternatingRowBackground="{StaticResource BgBrush}"
                          FontFamily="{StaticResource FontPoppins}"
                          FontSize="13">
                  <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                      <Setter Property="Background"  Value="{StaticResource BgBrush}"/>
                      <Setter Property="Foreground"  Value="{StaticResource Ink3Brush}"/>
                      <Setter Property="FontWeight"  Value="SemiBold"/>
                      <Setter Property="FontSize"    Value="11"/>
                      <Setter Property="Padding"     Value="12,8"/>
                      <Setter Property="BorderThickness" Value="0,0,0,1"/>
                      <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
                    </Style>
                  </DataGrid.ColumnHeaderStyle>
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="FECHA Y HORA"  Binding="{Binding FechaHora}" Width="160"/>
                    <DataGridTextColumn Header="TIPO"          Binding="{Binding TipoMarca}"  Width="140"/>
                    <DataGridTextColumn Header="RELOJ"         Binding="{Binding Reloj}"       Width="*"/>
                    <DataGridTextColumn Header="INCIDENCIA"    Binding="{Binding Incidencia}"  Width="200"/>
                  </DataGrid.Columns>
                </DataGrid>
              </Grid>

              <!-- Tab 2: Huellas -->
              <Grid x:Name="tabHuellas" Visibility="Collapsed">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,20">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="Registro de Huellas Digitales"
                             FontFamily="{StaticResource FontPoppins}" FontWeight="SemiBold"
                             FontSize="16" Foreground="{StaticResource InkBrush}"
                             VerticalAlignment="Center"/>
                  <TextBlock x:Name="lblHuellaCount" Grid.Column="1"
                             FontFamily="{StaticResource FontPoppins}" FontSize="13"
                             Foreground="{StaticResource Ink3Brush}" VerticalAlignment="Center"/>
                </Grid>

                <Grid Grid.Row="1">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>

                  <!-- Selector de dedo -->
                  <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource FormLabel}" Text="MANO DERECHA" Margin="0,0,0,6"/>
                    <Button x:Name="btnDedo1"  Content="Pulgar D"  Tag="1"  Height="34" Margin="0,0,0,4"  Style="{StaticResource FingerBtn}" Click="BtnDedo_Click"/>
                    <Button x:Name="btnDedo2"  Content="Índice D"  Tag="2"  Height="34" Margin="0,0,0,4"  Style="{StaticResource FingerBtn}" Click="BtnDedo_Click"/>
                    <Button x:Name="btnDedo3"  Content="Medio D"   Tag="3"  Height="34" Margin="0,0,0,4"  Style="{StaticResource FingerBtn}" Click="BtnDedo_Click"/>
                    <Button x:Name="btnDedo4"  Content="Anular D"  Tag="4"  Height="34" Margin="0,0,0,4"  Style="{StaticResource FingerBtn}" Click="BtnDedo_Click"/>
                    <Button x:Name="btnDedo5"  Content="Meñique D" Tag="5"  Height="34" Margin="0,0,0,16" Style="{StaticResource FingerBtn}" Click="BtnDedo_Click"/>
                    <TextBlock Style="{StaticResource FormLabel}" Text="MANO IZQUIERDA" Margin="0,0,0,6"/>
                    <Button x:Name="btnDedo6"  Content="Pulgar I"  Tag="6"  Height="34" Margin="0,0,0,4"  Style="{StaticResource FingerBtn}" Click="BtnDedo_Click"/>
                    <Button x:Name="btnDedo7"  Content="Índice I"  Tag="7"  Height="34" Margin="0,0,0,4"  Style="{StaticResource FingerBtn}" Click="BtnDedo_Click"/>
                    <Button x:Name="btnDedo8"  Content="Medio I"   Tag="8"  Height="34" Margin="0,0,0,4"  Style="{StaticResource FingerBtn}" Click="BtnDedo_Click"/>
                    <Button x:Name="btnDedo9"  Content="Anular I"  Tag="9"  Height="34" Margin="0,0,0,4"  Style="{StaticResource FingerBtn}" Click="BtnDedo_Click"/>
                    <Button x:Name="btnDedo10" Content="Meñique I" Tag="10" Height="34"                   Style="{StaticResource FingerBtn}" Click="BtnDedo_Click"/>
                  </StackPanel>

                  <!-- Panel derecho: estado + instrucciones (ecHost overlay via code-behind) -->
                  <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}"
                          CornerRadius="12" Effect="{StaticResource ShadowCard}"
                          Width="340">
                    <StackPanel Margin="20,16,20,16">
                      <TextBlock Text="LECTOR DE HUELLA"
                                 Style="{StaticResource TextEyebrow}" Margin="0,0,0,8"/>
                      <!-- Placeholder visual donde aparece el lector -->
                      <Border x:Name="ecPlaceholder" Height="200" CornerRadius="8"
                              Background="{StaticResource BgBrush}"
                              BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                              Margin="0,0,0,12">
                        <TextBlock Text="Coloca el dedo sobre el lector"
                                   FontFamily="{StaticResource FontPoppins}" FontSize="13"
                                   Foreground="{StaticResource Ink3Brush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   TextAlignment="Center"/>
                      </Border>
                      <TextBlock x:Name="lblEnrollStatus"
                                 FontFamily="{StaticResource FontPoppins}" FontSize="13"
                                 Foreground="{StaticResource Ink3Brush}"
                                 TextWrapping="Wrap" Margin="0,0,0,12"
                                 Text="← Selecciona un dedo para comenzar."/>
                      <Button x:Name="btnReiniciarEnroll" Content="Reiniciar enrolamiento"
                              Style="{StaticResource BtnSecondary}"
                              HorizontalAlignment="Stretch"
                              Click="BtnReiniciarEnroll_Click"/>
                    </StackPanel>
                  </Border>
                </Grid>
              </Grid>

              <!-- Tab 3: Comidas -->
              <Grid x:Name="tabComidas" Visibility="Collapsed">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="TIPOS DE COMIDA HABILITADOS"
                           Style="{StaticResource TextEyebrow}" Margin="0,0,0,16"/>
                <ItemsControl Grid.Row="1" x:Name="listaTiposComida">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{StaticResource SurfaceBrush}"
                              BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                              CornerRadius="{StaticResource RadiusInput}"
                              Padding="16,12" Margin="0,0,0,8">
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                          </Grid.ColumnDefinitions>
                          <CheckBox Grid.Column="0" IsChecked="{Binding Habilitado}"
                                    IsEnabled="False" VerticalAlignment="Center" Margin="0,0,14,0"/>
                          <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Nombre}" FontFamily="{StaticResource FontPoppins}"
                                       FontWeight="SemiBold" FontSize="14"
                                       Foreground="{StaticResource InkBrush}"/>
                            <TextBlock Text="{Binding Horario}" Style="{StaticResource TextHint}"/>
                          </StackPanel>
                          <Border Grid.Column="2" CornerRadius="{StaticResource RadiusBadge}"
                                  Padding="10,4" Background="{StaticResource AmberSoftBrush}">
                            <TextBlock Text="{Binding Valor}" FontFamily="{StaticResource FontPoppins}"
                                       FontWeight="SemiBold" FontSize="12"
                                       Foreground="{StaticResource AmberBrush}"/>
                          </Border>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Grid>

              <!-- Tab 4: Relojes -->
              <Grid x:Name="tabRelojes" Visibility="Collapsed">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="RELOJES ASIGNADOS"
                           Style="{StaticResource TextEyebrow}" Margin="0,0,0,16"/>
                <ItemsControl Grid.Row="1" x:Name="listaRelojes">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{StaticResource SurfaceBrush}"
                              BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                              CornerRadius="{StaticResource RadiusInput}"
                              Padding="16,12" Margin="0,0,0,8">
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition/>
                          </Grid.ColumnDefinitions>
                          <TextBlock Grid.Column="0" Text="{Binding Id}" Style="{StaticResource TextHint}"
                                     FontSize="10" VerticalAlignment="Center" Margin="0,0,14,0" Width="32"/>
                          <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Nombre}" FontFamily="{StaticResource FontPoppins}"
                                       FontWeight="SemiBold" FontSize="14"
                                       Foreground="{StaticResource InkBrush}"/>
                            <TextBlock Text="{Binding Ubicacion}" Style="{StaticResource TextHint}"/>
                          </StackPanel>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Grid>

            </Grid>
          </ScrollViewer>

          <!-- Footer navigation -->
          <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}"
                  BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0"
                  Padding="32,14">
            <Grid>
              <Button x:Name="btnVolver" Content="← Volver"
                      Style="{StaticResource BtnSecondary}"
                      HorizontalAlignment="Left" Height="42" Padding="20,0"
                      Click="BtnVolver_Click"/>
              <Button x:Name="btnSiguiente" Content="Siguiente →"
                      Style="{StaticResource BtnAccent}"
                      HorizontalAlignment="Right" Height="42" Padding="20,0"
                      Click="BtnSiguiente_Click"/>
            </Grid>
          </Border>

        </Grid>

      </Grid>
    </Grid>
  </Grid>
</UserControl>
